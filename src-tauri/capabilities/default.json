{
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    {
      "identifier": "fs:default",
      "allow": [
        { "path": "**/*" }
      ]
    },
    "fs:allow-read-text-file"
  ]
}
